# Copy to .env and fill in. Never commit .env.

# Google AI (Gemini) for drafting emails.
# Create a key: https://aistudio.google.com/apikey
# Paste the key below (no quotes).
GEMINI_API_KEY=

# Optional: receive start/finish summaries when running --live
NOTIFICATION_EMAIL=

# Copy for email drafts (used in LLM prompts). Adjust to your situation.
OUTREACH_SIGN_NAME=Your Name
OUTREACH_ROLE_LINE=a graduate student in data science at Example University
OUTREACH_SKILLS_BLURB=Background in data pipelines, ML, and analytics. Edit this to match your real experience.

# Optional: comma-separated substrings that must not appear alone in subject lines (e.g. family names)
# OUTREACH_SUBJECT_BLOCKLIST=

# Default address for python ghostwriter/daily_outreach.py --test (override per run with --test addr)
TEST_OUTREACH_EMAIL=your-email@example.com
